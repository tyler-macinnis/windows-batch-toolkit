{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Export Scripts Directory to ZIP",
			"type": "process",
			"command": "powershell.exe",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\tools\\export-scripts.ps1"
			],
			"group": "build",
			"problemMatcher": []
		}
	]
}